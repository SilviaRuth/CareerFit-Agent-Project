# CareerFit Agent runtime configuration
#
# The deterministic backend does not require secrets for local demo use.
# Copy this file to .env only when you want to override defaults.

# Optional advisory LLM layer. Disabled by default so deterministic parsing,
# matching, scoring, blocker flags, and benchmark behavior remain the source
# of truth.
ENABLE_LLM_GENERATION=false
# Optional natural-language extraction assist for /match. Disabled by default.
ENABLE_LLM_EXTRACTION=false
# Include evidence-level LLM extraction diagnostics in /match responses.
LLM_EXTRACTION_DEBUG=false
LLM_PROVIDER=openai
# Replace this placeholder with a valid provider model before setting
# ENABLE_LLM_GENERATION=true or ENABLE_LLM_EXTRACTION=true.
LLM_MODEL=replace-with-provider-model
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=12000

# Only set a key in a private local environment. Do not commit secrets.
# OPENAI_API_KEY=
# LLM_API_KEY=
