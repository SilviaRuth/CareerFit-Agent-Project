# CareerFit Agent runtime configuration
#
# The deterministic backend does not require secrets for local demo use.
# Copy this file to .env only when you want to override defaults.

# Optional advisory LLM layer. Disabled by default so deterministic parsing,
# matching, scoring, blocker flags, and benchmark behavior remain the source
# of truth.
ENABLE_LLM_GENERATION=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=800

# Only set a key in a private local environment. Do not commit secrets.
# OPENAI_API_KEY=
# LLM_API_KEY=
